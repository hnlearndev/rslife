# Exclude results folders
/src/result*/
/result*/

# Rust build output
**/target/
**/*.rs.bk

# Cargo package files
Cargo.lock

# IDE/editor files
.idea/
.vscode/
*.swp
*.swo

# Jujutsu VCS files
.jj/

# OS generated files
.DS_Store
Thumbs.db

# Logs
*.log

# Backup files
*~
*.bak

# Misc
node_modules/

# Personal reference files
README_FORMULAS.md

# Folder diagrams - ignore everything except .gif files
diagrams/*
!diagrams/*.gif

# Folder examples - ignore everything except .ods, .xlsx, and .rs files
examples/*
!examples/*.ods
!examples/*.xlsx
!examples/*.rs
